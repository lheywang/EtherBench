              <name>TI1SEL</name>
              <description>Selects tim_ti1[0..15] input
...
Refer to  for product specific implementation.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TI2SEL</name>
              <description>Selects tim_ti2[0..15] input
...
Refer to  for product specific implementation.</description>
              <bitOffset>8</bitOffset>
